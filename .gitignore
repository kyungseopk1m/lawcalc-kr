# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
coverage/
*.tsbuildinfo
*.draft.json
tests/golden/_wip/
packages/*/tests/golden/_wip/

# Environment
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Rust
target/
Cargo.lock

# Tauri
src-tauri/target/
apps/*/src-tauri/target/
apps/*/src-tauri/gen/
# 데스크톱 앱(바이너리 crate)은 의존성 재현성을 위해 Cargo.lock 을 추적한다.
# (미추적 시 CI 가 매번 latest 의존성을 받아 brotli 8.0.3 처럼 컴파일 깨진 버전이 유입됨)
!apps/desktop/src-tauri/Cargo.lock
apps/*/src-tauri/.taurignore

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editors
.idea/
.vscode/
*.swp

# Local backlog / private design notes (mirrored in for-claude/)
docs/plans/

# Internal spec/plan docs (not part of OSS distribution)
docs/INTEREST_FORMULAS.md
docs/history/
