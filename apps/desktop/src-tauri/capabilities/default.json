{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "LawCalc Korea 기본 권한 — 사용자 선택 경로 dialog open/save + 결과 표 클립보드 쓰기 + 정보 다이얼로그의 GitHub repo/Issues/LICENSE 외부 링크 open + 인앱 업데이트 확인/설치/재시작. fs scope 별도 권한 없음 (dialog가 반환한 절대 경로만 std::fs로 직접 사용).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "clipboard-manager:allow-write-text",
    "updater:default",
    "process:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://github.com/kyungseopk1m/lawcalc-kr" },
        { "url": "https://github.com/kyungseopk1m/lawcalc-kr/**" }
      ]
    }
  ]
}
