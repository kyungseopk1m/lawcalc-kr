{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LawCalc Korea",
  "version": "0.2.5",
  "identifier": "com.lawcalc.kr.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @lawcalc-kr/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @lawcalc-kr/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LawCalc Korea",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "한국 법률 계산 워크벤치 (이자/판결금/지연손해금)",
    "longDescription": "공개 법령과 공식 매뉴얼을 근거로 재구현한 데스크톱 법률 계산 도구. 100% 로컬 처리.",
    "icon": [
      "icons/16x16.png",
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxNDhGQkQ5NjBCMUE4MTIKUldRU3FMRmcyZnRJc1VPejA4ZmllK28wbzJDa3dqSzhNRy9xSFc2UEdJcUdFUlYzdXhIK1lqeTIK",
      "endpoints": [
        "https://github.com/kyungseopk1m/lawcalc-kr/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
