{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LawCalc Korea",
  "version": "0.1.0",
  "identifier": "com.lawcalc.kr.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @lawcalc-kr/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter @lawcalc-kr/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LawCalc Korea",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "한국 법률 계산 워크벤치 (이자/판결금/지연손해금)",
    "longDescription": "공개 법령과 공식 매뉴얼을 근거로 재구현한 데스크톱 법률 계산 도구. 100% 로컬 처리.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": {},
    "clipboard-manager": {}
  }
}
