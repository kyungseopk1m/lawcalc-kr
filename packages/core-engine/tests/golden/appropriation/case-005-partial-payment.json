    "totals": {
      "totalCostApplied": 0,
      "totalInterestApplied": 0,
      "totalPrincipalApplied": 1000,
      "remainingCost": 0,
      "remainingInterest": 0,
      "remainingPrincipal": 0,
      "remainingGrandTotal": 0
    },
    "claims": [
      {
        "claimId": "only-claim",
        "costApplied": 0,
        "interestApplied": 0,
        "principalApplied": 1000,
        "costBalanceAfter": 0,
        "interestBalanceAfter": 0,
        "principalBalanceAfter": 0,
        "totalApplied": 1000
      }
    ]
  }
