{
  "name": "@lawcalc-kr/core-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Pure TypeScript calculation engine for lawcalc-kr (Korean legal interest calculation). Decoupled from any UI shell so it can be unit-tested and golden-tested in isolation.",
  "license": "BUSL-1.1",
  "author": "kyungseopk1m",
  "homepage": "https://github.com/kyungseopk1m/lawcalc-kr#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyungseopk1m/lawcalc-kr.git",
    "directory": "packages/core-engine"
  },
  "bugs": {
    "url": "https://github.com/kyungseopk1m/lawcalc-kr/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:golden": "vitest run --config vitest.golden.config.ts"
  },
  "devDependencies": {
    "vitest": "^2.1.0"
  }
}
