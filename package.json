{
  "name": "lawcalc-kr",
  "version": "0.0.0",
  "private": true,
  "description": "한국 법률 계산 데스크톱 워크벤치 (Tauri + React + Rust). 판결금·지연손해금 이자 계산 MVP.",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "test:golden": "pnpm -r --if-present test:golden",
    "tauri:dev": "pnpm --filter @lawcalc-kr/desktop tauri dev",
    "tauri:build": "pnpm --filter @lawcalc-kr/desktop tauri build",
    "build:icons": "node scripts/build-icons.mjs"
  },
  "keywords": [
    "korean-law",
    "legal-calculator",
    "interest-calculator",
    "judgment-interest",
    "tauri",
    "lawcalc"
  ],
  "license": "AGPL-3.0-or-later",
  "author": "kyungseopk1m",
  "homepage": "https://github.com/kyungseopk1m/lawcalc-kr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyungseopk1m/lawcalc-kr.git"
  },
  "bugs": {
    "url": "https://github.com/kyungseopk1m/lawcalc-kr/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "eslint": "^9.26.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.5.3",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.32.0"
  },
  "pnpm": {
    "overrides": {
      "vitest": "^4.1.5"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
